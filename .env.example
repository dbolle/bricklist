# BrickList environment variables
# Copy this file to .env if needed (not required for normal use)
#
# The Rebrickable API key is entered via the Settings page in the app
# and stored in the local database. No environment variables are required
# to run the app.
#
# Optional: Override the database path (default: /data/bricklist.db)
# DATABASE_URL=sqlite:////data/bricklist.db
